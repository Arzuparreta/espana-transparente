# España Transparente — variables de entorno frontend
# Copia este archivo a `.env.local` y rellena los valores.
#
# Ambas variables son PÚBLICAS — viajan al navegador. La protección efectiva
# de la base de datos viene de las políticas RLS en Supabase.

# URL del proyecto Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://your-self-hosted-supabase.example.com

# Publishable/anon key (formato nuevo: sb_publishable_...).
# Las JWT legacy no funcionan con este proyecto.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only key. Never expose this in the browser.
# Required for signing private user avatar URLs.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Auth operations / CI checks.
AUTH_EXPECTED_SUPABASE_HOST=your-self-hosted-supabase.example.com
AUTH_MIN_USERS=1
AUTH_SMOKE_APP_URL=https://xn--espaatransparente-ixb.site
AUTH_SMOKE_EMAIL_DOMAIN=gmail.com

# Supabase Management API token with auth_config_write/project_admin_write.
# Required only for `npm run auth:configure`.
SUPABASE_ACCESS_TOKEN=sbp_xxx
