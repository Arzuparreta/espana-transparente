# España Transparente — variables de entorno ETL
# Copia este archivo a `.env` y rellena los valores.
#
# Los ETLs escriben directamente vía PostgreSQL (no usan REST/PostgREST),
# por lo que necesitan la connection string completa.

# Connection string de PostgreSQL hacia Supabase.
# Disponible en: Supabase Dashboard → Project Settings → Database
#   → Connection string → URI (modo "transaction pooler", puerto 6543).
# Este valor ES SECRETO — no commitearlo.
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:54322/postgres

# Opcionales — los módulos ETL tienen defaults hardcoded a este proyecto.
# Definir aquí solo si trabajas contra otra instancia.
# NEXT_PUBLIC_SUPABASE_URL=https://your-self-hosted-supabase.example.com
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Auth health / encrypted backups.
AUTH_EXPECTED_SUPABASE_HOST=your-self-hosted-supabase.example.com
AUTH_MIN_USERS=1
AUTH_BACKUP_ENCRYPTION_PASSPHRASE=change-me
